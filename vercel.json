{
  "rewrites": [
    {
      "source": "/index.html",
      "destination": "/pistacien-frontend-second/pages/index.html"
    },
    {
      "source": "/pages/:path*",
      "destination": "/pistacien-frontend-second/pages/:path*"
    },
    {
      "source": "/",
      "destination": "/pistacien-frontend-second/pages/index.html"
    },
    {
      "source": "/auth",
      "destination": "/pistacien-frontend-second/pages/auth.html"
    },
    {
      "source": "/auth.html",
      "destination": "/pistacien-frontend-second/pages/auth.html"
    },
    {
      "source": "/mens",
      "destination": "/pistacien-frontend-second/pages/mens.html"
    },
    {
      "source": "/mens.html",
      "destination": "/pistacien-frontend-second/pages/mens.html"
    },
    {
      "source": "/profile",
      "destination": "/pistacien-frontend-second/pages/profile.html"
    },
    {
      "source": "/profile.html",
      "destination": "/pistacien-frontend-second/pages/profile.html"
    },
    {
      "source": "/product",
      "destination": "/pistacien-frontend-second/pages/product.html"
    },
    {
      "source": "/product.html",
      "destination": "/pistacien-frontend-second/pages/product.html"
    },
    {
      "source": "/checkout",
      "destination": "/pistacien-frontend-second/pages/checkout.html"
    },
    {
      "source": "/checkout.html",
      "destination": "/pistacien-frontend-second/pages/checkout.html"
    },
    {
      "source": "/orders",
      "destination": "/pistacien-frontend-second/pages/orders.html"
    },
    {
      "source": "/orders.html",
      "destination": "/pistacien-frontend-second/pages/orders.html"
    },
    {
      "source": "/order",
      "destination": "/pistacien-frontend-second/pages/orders.html"
    },
    {
      "source": "/order.html",
      "destination": "/pistacien-frontend-second/pages/orders.html"
    },
    {
      "source": "/admin",
      "destination": "/pistacien-frontend-second/pages/admin.html"
    },
    {
      "source": "/css/:path*",
      "destination": "/pistacien-frontend-second/css/:path*"
    },
    {
      "source": "/js/:path*",
      "destination": "/pistacien-frontend-second/js/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/pistacien-frontend-second/assets/:path*"
    }
  ]
}
